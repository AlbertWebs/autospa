{
    "name": "autospa-desktop",
    "version": "1.1.3",
    "description": "AutoSpa Pro desktop app (offline-first Electron shell)",
    "private": true,
    "type": "module",
    "main": "main.js",
    "author": "AutoSpa",
    "scripts": {
        "electron:dev": "electron .",
        "electron:build": "electron-builder",
        "electron:build:win": "electron-builder --win",
        "electron:build:mac": "electron-builder --mac",
        "electron:build:linux": "electron-builder --linux"
    },
    "devDependencies": {
        "electron": "^35.0.0",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.autospa.desktop",
        "productName": "AutoSpa Pro",
        "directories": {
            "output": "dist",
            "buildResources": "build"
        },
        "files": [
            "main.js",
            "preload.js",
            "setup.js",
            "config.js",
            "package.json"
        ],
        "win": {
            "target": [
                "nsis",
                "msi"
            ],
            "artifactName": "${productName}-Setup-${version}.${ext}",
            "signAndEditExecutable": false
        },
        "mac": {
            "target": [
                "dmg"
            ],
            "category": "public.app-category.business"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "category": "Office"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
