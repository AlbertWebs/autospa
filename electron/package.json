{
    "name": "autospa-desktop",
    "version": "1.4.5",
    "description": "AutoSpa Pro desktop — live web UI online, operable offline shell",
    "private": true,
    "type": "module",
    "main": "main.js",
    "author": "AutoSpa",
    "scripts": {
        "copy-web-assets": "node scripts/copy-web-assets.js",
        "preelectron:dev": "node scripts/copy-web-assets.js",
        "electron:dev": "electron .",
        "preelectron:build": "node scripts/copy-web-assets.js",
        "preelectron:build:win": "node scripts/copy-web-assets.js",
        "electron:build": "electron-builder",
        "electron:build:win": "electron-builder --win",
        "postinstall": "electron-builder install-app-deps"
    },
    "dependencies": {
        "better-sqlite3": "^11.8.1",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "electron": "^35.0.0",
        "electron-builder": "^25.1.8"
    },
    "build": {
        "appId": "com.autospa.desktop",
        "productName": "AutoSpa Pro",
        "directories": {
            "output": "dist",
            "buildResources": "build"
        },
        "files": [
            "main.js",
            "preload.cjs",
            "config.js",
            "src/**/*",
            "renderer/**/*",
            "package.json"
        ],
        "asarUnpack": [
            "node_modules/better-sqlite3/**/*"
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "artifactName": "${productName}-Setup-${version}.${ext}",
            "signAndEditExecutable": false
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
